---
import '../styles/global.css';
import Sidebar from '../components/Sidebar.astro';
import { withBase } from '../lib/urls';

const { title, description, sidebar } = Astro.props;
const pageTitle = title ? `${title} | Catatan Arumuki` : 'Catatan Arumuki';
const metaDescription = description ?? 'A quiet corner for thoughtful diary entries.';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={metaDescription} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:type" content="website" />
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <h1 class="site-title"><a href={withBase('')}>Catatan Arumuki</a></h1>
        <nav class="site-nav" aria-label="Primary">
          <a href={withBase('')}>Home</a>
          <a href={withBase('cerita/')}>Cerita</a>
          <a href={withBase('about/')}>About</a>
          <a href={withBase('archive/')}>Archive</a>
          <a href={withBase('categories/')}>Categories</a>
        </nav>
        <div class="site-wordmark" aria-hidden="true">
          <span class="wordmark-top">CATATAN</span>
          <span class="wordmark-bottom">ARUMUKI</span>
        </div>
      </div>
    </header>

    <div class="container page">
      <main>
        <slot />
      </main>
      <Sidebar {...sidebar} />
    </div>

    <footer class="footer">
      <div class="container">
        <p>Written with Astro. Crafted for quiet evenings and careful memories.</p>
      </div>
    </footer>
  </body>
</html>
