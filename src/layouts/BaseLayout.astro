---
import '../styles/global.css';
import Sidebar from '../components/Sidebar.astro';
import { withBase } from '../lib/urls';

const { title, description, sidebar } = Astro.props;
const pageTitle = title ? `${title} | Catatan Arumuki` : 'Catatan Arumuki';
const metaDescription = description ?? 'A quiet corner for thoughtful diary entries.';
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={metaDescription} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:type" content="website" />
    <script is:inline>
      (() => {
        const stored = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const theme = stored ?? (prefersDark ? 'dark' : 'light');
        document.documentElement.dataset.theme = theme;
      })();
    </script>
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <h1 class="site-title"><a href={withBase('')}>Catatan Arumuki</a></h1>
        <nav class="site-nav" aria-label="Primary">
          <a href={withBase('')}>Home</a>
          <a href={withBase('about/')}>About</a>
          <a href={withBase('archive/')}>Archive</a>
          <a href={withBase('categories/')}>Categories</a>
          <button class="theme-toggle" type="button" data-theme-toggle>Dark mode</button>
        </nav>
      </div>
    </header>

    <div class="container page">
      <main>
        <slot />
      </main>
      <Sidebar {...sidebar} />
    </div>

    <footer class="footer">
      <div class="container">
        <p>Written with Astro. Crafted for quiet evenings and careful memories.</p>
      </div>
    </footer>

    <script is:inline type="module">
      const button = document.querySelector('[data-theme-toggle]');
      if (button) {
        const applyLabel = (theme) => {
          button.textContent = theme === 'dark' ? 'Light mode' : 'Dark mode';
          button.setAttribute('aria-pressed', theme === 'dark');
        };

        const currentTheme = document.documentElement.dataset.theme || 'light';
        applyLabel(currentTheme);

        button.addEventListener('click', () => {
          const nextTheme =
            document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
          document.documentElement.dataset.theme = nextTheme;
          localStorage.setItem('theme', nextTheme);
          applyLabel(nextTheme);
        });
      }
    </script>
  </body>
</html>
