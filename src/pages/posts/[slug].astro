---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getVisiblePosts } from '../../lib/content';
import { buildSidebar } from '../../lib/sidebar';
import { formatDate } from '../../lib/date';
import { withBase } from '../../lib/urls';
import { getPostSlug } from '../../lib/posts';
import { render } from 'astro:content';
import { defaultCoverImage } from '../../lib/site';

export async function getStaticPaths() {
  const posts = await getVisiblePosts();
  return posts.map((post) => ({
    params: { slug: getPostSlug(post) },
    props: { post },
  }));
}

const posts = await getVisiblePosts();
const sidebar = buildSidebar(posts);
const { post } = Astro.props;
const { Content } = await render(post);
const words = post.body.trim().split(/\s+/).filter(Boolean).length;
const readingTime = Math.max(1, Math.ceil(words / 200));

const currentSlug = getPostSlug(post);
const currentIndex = posts.findIndex((item) => getPostSlug(item) === currentSlug);
const previousPost = currentIndex >= 0 ? posts[currentIndex + 1] : null;
const nextPost = currentIndex > 0 ? posts[currentIndex - 1] : null;
const postTags = new Set(post.data.tags ?? []);
const scoredPosts = posts
  .filter((item) => getPostSlug(item) !== currentSlug)
  .map((item) => {
    const overlap = (item.data.tags ?? []).filter((tag) => postTags.has(tag)).length;
    const sameCategory = item.data.category === post.data.category ? 2 : 0;
    return { item, score: sameCategory + overlap };
  })
  .sort((a, b) => b.score - a.score || b.item.data.date.valueOf() - a.item.data.date.valueOf());
const matchedRelatedPosts = scoredPosts
  .filter(({ score }) => score > 0)
  .map(({ item }) => item)
  .slice(0, 3);
const relatedPosts =
  matchedRelatedPosts.length > 0
    ? matchedRelatedPosts
    : scoredPosts.map(({ item }) => item).slice(0, 3);
---

<BaseLayout title={post.data.title} description={post.data.description} sidebar={sidebar}>
  <article class="post-detail">
    <div class="reading-progress" data-reading-progress aria-hidden="true"></div>
    <a href={withBase('')}>← Back to Home</a>
    <h1>{post.data.title}</h1>
    <div class="post-meta">
      <span>{formatDate(post.data.date)}</span>
      <span>{readingTime} min read</span>
      <a class="badge" href={withBase(`category/${encodeURIComponent(post.data.category)}/`)}>
        {post.data.category}
      </a>
    </div>

    {post.data.tags?.length ? (
      <div class="tags">
        {post.data.tags.map((tag) => (
          <span class="tag">{tag}</span>
        ))}
      </div>
    ) : null}

    <div class="cover">
      <img src={withBase(post.data.coverImage ?? defaultCoverImage)} alt={post.data.title} loading="lazy" />
    </div>

    <div class="post-content">
      <Content />
    </div>

    <div class="post-meta" style="margin-top: 2rem;">
      {previousPost ? (
        <a href={withBase(`posts/${getPostSlug(previousPost)}/`)}>← Previous entry</a>
      ) : (
        <span></span>
      )}
      {nextPost ? (
        <a href={withBase(`posts/${getPostSlug(nextPost)}/`)}>Next entry →</a>
      ) : (
        <span></span>
      )}
    </div>

    {relatedPosts.length ? (
      <section class="related-posts">
        <h2>Related posts</h2>
        <div class="post-grid">
          {relatedPosts.map((related) => (
            <article class="post-card">
              <a class="post-card__media" href={withBase(`posts/${getPostSlug(related)}/`)}>
                <img
                  src={withBase(related.data.coverImage ?? defaultCoverImage)}
                  alt={related.data.title}
                  loading="lazy"
                  width="640"
                  height="360"
                />
              </a>
              <div class="post-card__body">
                <h3><a href={withBase(`posts/${getPostSlug(related)}/`)}>{related.data.title}</a></h3>
                <div class="post-meta">
                  <span>{formatDate(related.data.date)}</span>
                  <span>{related.data.category}</span>
                </div>
              </div>
            </article>
          ))}
        </div>
      </section>
    ) : null}

    <button class="back-to-top" type="button" data-back-to-top aria-label="Back to top">
      ↑ Top
    </button>
  </article>

  <script is:inline>
    (() => {
      const progress = document.querySelector('[data-reading-progress]');
      const backToTop = document.querySelector('[data-back-to-top]');
      if (!(progress instanceof HTMLElement) || !(backToTop instanceof HTMLButtonElement)) return;

      const updateUI = () => {
        const maxScroll = document.documentElement.scrollHeight - window.innerHeight;
        const ratio = maxScroll > 0 ? window.scrollY / maxScroll : 0;
        progress.style.transform = `scaleX(${Math.min(Math.max(ratio, 0), 1)})`;
        backToTop.classList.toggle('visible', window.scrollY > 320);
      };

      backToTop.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });

      window.addEventListener('scroll', updateUI, { passive: true });
      updateUI();
    })();
  </script>
</BaseLayout>

<style>
  .related-posts {
    margin-top: 2.25rem;
  }

  .related-posts h2 {
    margin-bottom: 0.8rem;
  }

  .post-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  .post-card {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--card);
    overflow: hidden;
  }

  .post-card__media {
    display: block;
    aspect-ratio: 16 / 9;
  }

  .post-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 0;
  }

  .post-card__body {
    padding: 0.85rem 1rem 1.1rem;
  }

  .post-card__body h3 {
    margin: 0;
    font-size: 1rem;
    line-height: 1.4;
  }

  @media (min-width: 680px) {
    .post-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 1080px) {
    .post-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>
