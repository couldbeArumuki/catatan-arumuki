---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getVisiblePosts } from '../lib/content';
import { buildSidebar } from '../lib/sidebar';
import { formatDate } from '../lib/date';
import { withBase } from '../lib/urls';
import { getPostSlug } from '../lib/posts';
import { defaultAvatar, defaultCoverImage, siteProfile } from '../lib/site';

const posts = await getVisiblePosts();
const sidebar = buildSidebar(posts);
const homepageSearchData = posts.map((post) => ({
  slug: getPostSlug(post),
  url: withBase(`posts/${getPostSlug(post)}/`),
  title: post.data.title,
  description: post.data.description,
  category: post.data.category,
  tags: post.data.tags ?? [],
}));
const categorySummary = sidebar.categories.slice(0, 3);
---

<BaseLayout title="Home" description="Catatan hangat sehari-hari dari Arumuki." sidebar={sidebar}>
  <section class="hero card" style="text-align: center; border: none; padding-top: 0; box-shadow: none;">
    <div class="hero__content">
      <img src={withBase(defaultAvatar)} alt="Arumuki avatar illustration" width="180" height="180" style="border-radius: 50%; object-fit: cover; margin: 0 auto 1.5rem;" />
      <p class="hero__eyebrow" style="margin-bottom: 0.5rem; letter-spacing: 0.2em; text-transform: uppercase;">Hello, I'm Jane</p>
      <h1 style="font-family: 'Georgia', serif; font-size: 2.5rem; margin: 0 0 1rem; color: var(--text); letter-spacing: 0.1em; font-weight: normal;">LIFESTYLE BLOG</h1>
      <p style="color: var(--muted); max-width: 600px; margin: 0 auto;">Welcome to my blog, covering my everyday life journey and other favorite things. So glad you've found this blog, please enjoy and stay awhile!</p>
    </div>
  </section>

  <section class="card home-search" data-home-search data-posts={JSON.stringify(homepageSearchData)} style="margin-bottom: 3rem; text-align: center; border: none; box-shadow: none;">
    <h2 style="font-size: 1rem; margin-bottom: 1rem; border-bottom: 1px solid var(--border); padding-bottom: 0.5rem; display: inline-block; padding-left: 2rem; padding-right: 2rem;">SEARCH</h2>
    <input
      id="home-search-input"
      class="search-input"
      type="search"
      placeholder="Search posts..."
      aria-label="Search posts from homepage"
      data-home-search-input
    />
    <div class="search-results" aria-live="polite" data-home-search-results></div>
  </section>

  <section id="latest-posts">
    <h2 style="font-size: 1rem; margin-bottom: 2rem; border-bottom: 1px solid var(--border); padding-bottom: 0.5rem; text-align: center;">LATEST ENTRIES</h2>
    <div class="post-grid">
      {posts.slice(0, 5).map((post) => {
        const slug = getPostSlug(post);
        const coverImage = withBase(post.data.coverImage ?? defaultCoverImage);
        return (
          <article class="post-card">
            <div class="post-meta">
              <span>{formatDate(post.data.date)}</span>
              <span>|</span>
              <a class="badge" href={withBase(`category/${encodeURIComponent(post.data.category)}/`)}>
                {post.data.category}
              </a>
            </div>
            
            <div class="post-card__body">
              <h3>
                <a href={withBase(`posts/${slug}/`)}>{post.data.title}</a>
              </h3>
            </div>
            
            <a class="post-card__media" href={withBase(`posts/${slug}/`)}>
              <img
                src={coverImage}
                alt={post.data.title}
                loading="lazy"
                width="640"
                height="360"
              />
            </a>
            
            <p style="color: var(--text);">{post.data.description}</p>
            <a href={withBase(`posts/${slug}/`)} style="display: inline-block; margin-top: 1rem; border: 1px solid var(--border); padding: 0.5rem 1rem; text-transform: uppercase; font-size: 0.8rem; letter-spacing: 0.1em;">Read More</a>
          </article>
        );
      })}
    </div>
  </section>
</BaseLayout>

<script is:inline type="module">
  const root = document.querySelector('[data-home-search]');
  const input = root?.querySelector('[data-home-search-input]');
  const results = root?.querySelector('[data-home-search-results]');

  const matchPost = (post, query) => {
    const fields = [post.title, post.description, post.category, ...(post.tags ?? [])]
      .join(' ')
      .toLowerCase();
    return fields.includes(query);
  };

  const renderResults = (items, query) => {
    if (!results) return;
    if (!query) {
      results.innerHTML = '';
      return;
    }

    if (!items.length) {
      results.innerHTML = '<small>No matching posts.</small>';
      return;
    }

    results.innerHTML = items
      .map(
        (item) =>
          `<a href="${item.url}"><strong>${item.title}</strong><br /><small>${item.category}</small></a>`,
      )
      .join('');
  };

  if (root instanceof HTMLElement && input instanceof HTMLInputElement) {
    const posts = JSON.parse(root.dataset.posts || '[]');
    const update = () => {
      const query = input.value.trim().toLowerCase();
      const filtered = query ? posts.filter((post) => matchPost(post, query)).slice(0, 8) : [];
      renderResults(filtered, query);
    };
    input.addEventListener('input', update);
  }
</script>
