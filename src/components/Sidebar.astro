---
import { formatDate } from '../lib/date';
import { withBase } from '../lib/urls';
import { defaultCoverImage } from '../lib/site';

const {
  aboutText,
  categories,
  tags,
  popularPosts = [],
  searchIndex,
  tagLimit = 12,
} = Astro.props;

const tagList = tags.slice(0, tagLimit);
const searchData = searchIndex.map((post) => ({
  ...post,
  url: withBase(`posts/${post.slug}/`),
}));
---

<aside>
  <div class="card">
    <h2>About</h2>
    <p>{aboutText}</p>
  </div>

  <div class="card" data-search data-posts={JSON.stringify(searchData)}>
    <label for="search-input"><strong>Search</strong></label>
    <input
      id="search-input"
      class="search-input"
      type="search"
      placeholder="Search entries"
      aria-label="Search posts"
      data-search-input
    />
    <div class="search-results" aria-live="polite" data-search-results></div>
  </div>

  <div class="card">
    <h2>Categories</h2>
    <ul class="list">
      {categories.map((category) => (
        <li>
          <a href={withBase(`category/${encodeURIComponent(category.name)}/`)}>
            {category.name} ({category.count})
          </a>
        </li>
      ))}
    </ul>
  </div>

  <div class="card">
    <h2>Tags</h2>
    <div class="tags">
      {tagList.map((tag) => (
        <span class="tag">{tag.name}</span>
      ))}
    </div>
  </div>

  <div class="card">
    <h2>Popular posts</h2>
    {popularPosts.length ? (
      <div class="popular-grid">
        {popularPosts.map((post) => (
          <a
            class="popular-item"
            href={withBase(`posts/${post.slug}/`)}
            aria-label={`Read ${post.title}`}
          >
            <img
              src={withBase(post.coverImage ?? defaultCoverImage)}
              alt={post.title}
              loading="lazy"
              width="360"
              height="360"
            />
            <span class="popular-overlay">
              <strong>{post.title}</strong>
              <small>{formatDate(post.date)}</small>
            </span>
          </a>
        ))}
      </div>
    ) : (
      <p class="muted">No popular posts yet.</p>
    )}
  </div>
</aside>

<style>
  .popular-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
    margin-top: 1rem;
  }

  .popular-item {
    position: relative;
    display: block;
    border-radius: 12px;
    overflow: hidden;
    aspect-ratio: 1 / 1;
    background: rgba(106, 74, 60, 0.08);
  }

  .popular-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: 0;
  }

  .popular-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(140deg, rgba(106, 74, 60, 0.2), rgba(106, 74, 60, 0.05));
  }

  .popular-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 0.2rem;
    padding: 0.75rem;
    color: #fff;
    background: linear-gradient(180deg, rgba(0, 0, 0, 0) 35%, rgba(0, 0, 0, 0.7));
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .popular-overlay small {
    opacity: 0.85;
  }

  .popular-item:hover .popular-overlay,
  .popular-item:focus-visible .popular-overlay {
    opacity: 1;
  }

  .muted {
    color: var(--muted);
    margin: 0.5rem 0 0;
  }
</style>

<script is:inline type="module">
  const roots = document.querySelectorAll('[data-search]');
  const matchPost = (post, query) => {
    const fields = [post.title, post.description, post.category, ...(post.tags ?? [])]
      .join(' ')
      .toLowerCase();
    return fields.includes(query);
  };

  const renderResults = (container, items, query) => {
    if (!query) {
      container.innerHTML = '';
      return;
    }

    if (!items.length) {
      container.innerHTML = '<small>No matching posts.</small>';
      return;
    }

    container.innerHTML = items
      .map(
        (item) =>
          `<a href="${item.url}"><strong>${item.title}</strong><br /><small>${item.category}</small></a>`,
      )
      .join('');
  };

  roots.forEach((root) => {
    const input = root.querySelector('[data-search-input]');
    const results = root.querySelector('[data-search-results]');
    if (!input || !results) return;
    const posts = JSON.parse(root.dataset.posts || '[]');

    const update = () => {
      const query = input.value.trim().toLowerCase();
      const filtered = query
        ? posts.filter((post) => matchPost(post, query)).slice(0, 8)
        : [];
      renderResults(results, filtered, query);
    };

    input.addEventListener('input', update);
  });
</script>
