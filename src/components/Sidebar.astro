---
import { formatDate } from '../lib/date';
import { withBase } from '../lib/urls';
import { defaultCoverImage } from '../lib/site';

const {
  aboutText,
  categories,
  tags,
  popularPosts = [],
  searchIndex,
  tagLimit = 12,
} = Astro.props;

const tagList = tags.slice(0, tagLimit);
const searchData = searchIndex.map((post) => ({
  ...post,
  url: withBase(`posts/${post.slug}/`),
}));
---

<aside>
  <div class="card" style="text-align: center;">
    <h2>ABOUT ME</h2>
    <img src={withBase(defaultCoverImage)} alt="About" style="margin-bottom: 1rem; border-radius: 0; width: 100%; aspect-ratio: 1; object-fit: cover;" />
    <p style="font-size: 0.9rem; color: var(--text);">{aboutText}</p>
  </div>

  <div class="card" data-search data-posts={JSON.stringify(searchData)}>
    <h2>SEARCH</h2>
    <input
      id="search-input"
      class="search-input"
      type="search"
      placeholder="Search..."
      aria-label="Search posts"
      data-search-input
    />
    <div class="search-results" aria-live="polite" data-search-results></div>
  </div>

  <div class="card">
    <h2>CATEGORIES</h2>
    <ul class="list" style="text-align: center; text-transform: uppercase; font-size: 0.85rem; letter-spacing: 0.05em;">
      {categories.map((category) => (
        <li style="border-bottom: 1px solid var(--border); padding-bottom: 0.5rem; margin-bottom: 0.5rem;">
          <a href={withBase(`category/${encodeURIComponent(category.name)}/`)}>
            {category.name} ({category.count})
          </a>
        </li>
      ))}
    </ul>
  </div>

  <div class="card">
    <h2>TAGS</h2>
    <div class="tags" style="justify-content: center;">
      {tagList.map((tag) => (
        <span class="tag">{tag.name}</span>
      ))}
    </div>
  </div>

  <div class="card">
    <h2>POPULAR POSTS</h2>
    {popularPosts.length ? (
      <div class="popular-grid">
        {popularPosts.map((post) => (
          <a
            class="popular-item"
            href={withBase(`posts/${post.slug}/`)}
            aria-label={`Read ${post.title}`}
          >
            <img
              src={withBase(post.coverImage ?? defaultCoverImage)}
              alt={post.title}
              loading="lazy"
            />
            <strong style="text-align: center; font-size: 0.85rem; font-weight: normal; margin-top: 0.5rem;">{post.title}</strong>
          </a>
        ))}
      </div>
    ) : (
      <p class="muted">No popular posts yet.</p>
    )}
  </div>
</aside>

<script is:inline type="module">
  const roots = document.querySelectorAll('[data-search]');
  const matchPost = (post, query) => {
    const fields = [post.title, post.description, post.category, ...(post.tags ?? [])]
      .join(' ')
      .toLowerCase();
    return fields.includes(query);
  };

  const renderResults = (container, items, query) => {
    if (!query) {
      container.innerHTML = '';
      return;
    }

    if (!items.length) {
      container.innerHTML = '<small>No matching posts.</small>';
      return;
    }

    container.innerHTML = items
      .map(
        (item) =>
          `<a href="${item.url}"><strong>${item.title}</strong><br /><small>${item.category}</small></a>`,
      )
      .join('');
  };

  roots.forEach((root) => {
    const input = root.querySelector('[data-search-input]');
    const results = root.querySelector('[data-search-results]');
    if (!input || !results) return;
    const posts = JSON.parse(root.dataset.posts || '[]');

    const update = () => {
      const query = input.value.trim().toLowerCase();
      const filtered = query
        ? posts.filter((post) => matchPost(post, query)).slice(0, 8)
        : [];
      renderResults(results, filtered, query);
    };

    input.addEventListener('input', update);
  });
</script>
